# ─────────────────────────────────────────────
# MedPredict — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ─────────────────────────────────────────────

# ── Django ────────────────────────────────────
SECRET_KEY=changeme-generate-a-real-key-here
DEBUG=True

# ── PostgreSQL ────────────────────────────────
POSTGRES_DB=curamedical
POSTGRES_USER=curamedical
POSTGRES_PASSWORD=curamedical_password
POSTGRES_HOST=db

# ── CORS / Hosts ──────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Service IA ────────────────────────────────
IA_SERVICE_URL=http://ia-service:5000

# ── n8n Webhook ───────────────────────────────
# URL du webhook n8n pour les notifications (ordonnance disponible)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/prescriptions

# ── Email SMTP ────────────────────────────────
# Laisser vide en dev → les emails s'affichent dans la console Django
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre.email@gmail.com
EMAIL_HOST_PASSWORD=votre_mot_de_passe_application
DEFAULT_FROM_EMAIL=CuraMedical <votre.email@gmail.com>

# ── Twilio / WhatsApp ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
# Mettre True en production pour vérifier la signature des webhooks Twilio
TWILIO_VALIDATE_SIGNATURE=False
# URL publique du backend (servie par le service ngrok) — utilisée par Twilio
# pour les webhooks et pour les liens PDF envoyés sur WhatsApp
PUBLIC_BASE_URL=https://votre-domaine.ngrok-free.dev

# ── ngrok (tunnel public, service Docker) ─────
# Authtoken depuis https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Domaine réservé ngrok (sans https://) — doit correspondre à PUBLIC_BASE_URL
NGROK_DOMAIN=votre-domaine.ngrok-free.dev

# ── IA LLM (optionnel — pour le chatbot) ─────
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Frontend ──────────────────────────────────
VITE_API_URL=http://localhost:8000
